<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlAgMonitor.ViewModels"
        xmlns:conv="using:SqlAgMonitor.Converters"
        xmlns:controls="using:SqlAgMonitor.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="SqlAgMonitor.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="SQL Server AG Monitor"
        Width="1280" Height="800"
        MinWidth="900" MinHeight="600">

    <Window.Resources>
        <conv:UtcToLocalConverter x:Key="UtcToLocal" />
        <conv:ServiceDotColorConverter x:Key="ServiceDotColorConverter" />
    </Window.Resources>

    <Window.DataTemplates>
        <!-- Alert History tab content -->
        <DataTemplate DataType="vm:AlertHistoryViewModel">
            <DockPanel>
                <DockPanel DockPanel.Dock="Bottom" Margin="8,4,8,8">
                    <Button Content="Refresh" Command="{Binding RefreshCommand}" 
                            DockPanel.Dock="Left" Padding="12,4" />
                    <TextBlock Text="{Binding StatusText}" 
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               FontSize="12" Opacity="0.6" />
                </DockPanel>
                
                <DataGrid x:Name="AlertHistoryGrid"
                          ItemsSource="{Binding Events}" 
                          IsReadOnly="True" 
                          GridLinesVisibility="Horizontal"
                          CanUserReorderColumns="True"
                          CanUserResizeColumns="True"
                          CanUserSortColumns="True"
                          Margin="4"
                          Loaded="AlertHistoryGrid_Loaded"
                          x:CompileBindings="False">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="Time" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Timestamp, Converter={StaticResource UtcToLocal}, ConverterParameter='yyyy-MM-dd HH:mm:ss'}"
                                               VerticalAlignment="Center" Margin="4,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Severity" Binding="{Binding Severity}" Width="80" />
                        <DataGridTextColumn Header="Type" Binding="{Binding AlertType}" Width="140" />
                        <DataGridTextColumn Header="Group" Binding="{Binding GroupName}" Width="130" />
                        <DataGridTextColumn Header="Replica" Binding="{Binding ReplicaName}" Width="130" />
                        <DataGridTextColumn Header="Database" Binding="{Binding DatabaseName}" Width="130" />
                        <DataGridTextColumn Header="Message" Binding="{Binding Message}" Width="300" />
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </DataTemplate>
        
        <!-- Monitor tab content (topology + grid) -->
        <DataTemplate DataType="vm:MonitorTabViewModel">
            <Grid RowDefinitions="*,4,*" x:CompileBindings="False"
                  Loaded="SplitGrid_Loaded">
                <!-- Topology View (top) -->
                <Border Grid.Row="0" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                        BorderThickness="1" CornerRadius="4" Margin="4"
                        ClipToBounds="True">
                    <controls:TopologyControl AgInfo="{Binding AgInfo}" 
                                              DagInfo="{Binding DagInfo}"
                                              SelectedReplica="{Binding SelectedReplicaName}" />
                </Border>

                <!-- Splitter -->
                <GridSplitter Grid.Row="1" ResizeDirection="Rows" 
                              Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" />

                <!-- Data Grid (bottom) -->
                <Border Grid.Row="2" BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}" 
                        BorderThickness="1" CornerRadius="4" Margin="4">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" 
                                    Spacing="8" Margin="8,4">
                            <TextBlock Text="Database Replica States" FontWeight="SemiBold" 
                                       VerticalAlignment="Center" />
                            <TextBlock Text="{Binding FilterDescription}" Opacity="0.6"
                                       VerticalAlignment="Center" FontSize="12" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding PivotRows}" 
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  CanUserSortColumns="True"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="True"
                                  GridLinesVisibility="Horizontal"
                                  Margin="4"
                                  x:CompileBindings="False"
                                  Loaded="DataGrid_Loaded">
                            <!-- Columns are generated dynamically in code-behind -->
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.DataTemplates>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.KeyBindings>
        <KeyBinding Gesture="F5" Command="{Binding RefreshCommand}" />
    </Window.KeyBindings>

    <DockPanel>
        <!-- Top Menu Bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings..." Command="{Binding OpenSettingsCommand}" />
                <Separator />
                <MenuItem Header="E_xit" Command="{Binding ExitCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Alert _History" Command="{Binding ToggleAlertHistoryCommand}" />
                <MenuItem Header="_Statistics..." Command="{Binding OpenStatisticsCommand}" />
            </MenuItem>
            <MenuItem Header="_Monitoring">
                <MenuItem Header="_Add AG/DAG..." Command="{Binding AddGroupCommand}" />
                <MenuItem Header="_Remove Current AG/DAG..." Command="{Binding RemoveGroupCommand}" />
                <Separator />
                <MenuItem Header="Re_fresh Now" Command="{Binding RefreshCommand}" 
                          InputGesture="F5" />
                <Separator />
                <MenuItem Header="_Pause All" Command="{Binding PauseAllCommand}" 
                          IsEnabled="{Binding IsNotAllPaused}" />
                <MenuItem Header="_Resume All" Command="{Binding ResumeAllCommand}" 
                          IsEnabled="{Binding IsAllPaused}" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="Open _Log Directory" Command="{Binding OpenLogDirectoryCommand}" />
                <Separator />
                <MenuItem Header="_About" Command="{Binding AboutCommand}" />
            </MenuItem>
        </Menu>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="8,4">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="{Binding StatusText}" 
                           VerticalAlignment="Center" Opacity="0.7" FontSize="12" />
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding ConnectionSummary}" VerticalAlignment="Center" FontSize="12" />
                    <TextBlock Text="{Binding LastPolledText}" VerticalAlignment="Center" 
                               FontSize="12" Opacity="0.6" />
                    <Border Background="#CCCC3300" CornerRadius="3" Padding="8,2" 
                            IsVisible="{Binding IsAllPaused}" VerticalAlignment="Center">
                        <TextBlock Text="⏸  PAUSED" FontSize="11" FontWeight="SemiBold" 
                                   Foreground="White" VerticalAlignment="Center" />
                    </Border>
                    <Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center"
                            IsVisible="{Binding IsServiceMode}">
                        <TextBlock FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center">
                            <Run Text="●" Foreground="{Binding IsServiceConnected, 
                                Converter={StaticResource ServiceDotColorConverter}}" />
                            <Run Text="{Binding ServiceConnectionText}" />
                        </TextBlock>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Main Content: Tab Control -->
        <Panel>
            <!-- Tab control — always visible since Alert History is always present -->
            <TabControl ItemsSource="{Binding AllTabs}" SelectedItem="{Binding SelectedTab}"
                        Margin="4"
                        IsVisible="{Binding AllTabs.Count}">
                <TabControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6" x:CompileBindings="False">
                            <Ellipse Width="10" Height="10" Fill="{Binding HealthBrush}" />
                            <TextBlock Text="{Binding TabTitle}" />
                        </StackPanel>
                    </DataTemplate>
                </TabControl.ItemTemplate>
            </TabControl>
        </Panel>
    </DockPanel>
</Window>
