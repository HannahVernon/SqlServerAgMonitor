<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SqlAgMonitor.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="650"
        x:Class="SqlAgMonitor.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="600" Height="650"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Design.DataContext>
        <vm:SettingsViewModel/>
    </Design.DataContext>

    <DockPanel Margin="16">
        <!-- Bottom buttons -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="Save" Command="{Binding SaveCommand}" Classes="accent" MinWidth="80" />
            <Button Content="Cancel" Command="{Binding CancelCommand}" MinWidth="80" />
        </StackPanel>

        <!-- Settings tabs -->
        <TabControl>
            <!-- General -->
            <TabItem Header="General">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="General Settings" FontWeight="Bold" FontSize="16" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Default Polling Interval (seconds)" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding GlobalPollingIntervalSeconds}" 
                                           Minimum="5" Maximum="300" Increment="1" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <TextBlock Text="Theme" />
                            <ComboBox x:CompileBindings="False" 
                                      ItemsSource="{Binding ThemeOptions}" 
                                      SelectedItem="{Binding Theme}"
                                      Width="200" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Email -->
            <TabItem Header="Email">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Email Notification Settings" FontWeight="Bold" FontSize="16" />

                        <CheckBox Content="Enable Email Notifications" IsChecked="{Binding EmailEnabled}" />

                        <StackPanel Spacing="4" IsEnabled="{Binding EmailEnabled}">
                            <TextBlock Text="SMTP Server" />
                            <TextBox Text="{Binding SmtpServer}" Watermark="smtp.example.com" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding EmailEnabled}">
                            <TextBlock Text="SMTP Port" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding SmtpPort}" Minimum="1" Maximum="65535" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>

                        <CheckBox Content="Use TLS" IsChecked="{Binding UseTls}" IsEnabled="{Binding EmailEnabled}" />

                        <StackPanel Spacing="4" IsEnabled="{Binding EmailEnabled}">
                            <TextBlock Text="From Address" />
                            <TextBox Text="{Binding FromAddress}" Watermark="monitor@example.com" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding EmailEnabled}">
                            <TextBlock Text="To Addresses (semicolon-separated)" />
                            <TextBox Text="{Binding ToAddresses}" Watermark="admin@example.com; dba@example.com" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding EmailEnabled}">
                            <TextBlock Text="Username (optional)" />
                            <TextBox Text="{Binding EmailUsername}" Watermark="Optional SMTP username" />
                        </StackPanel>

                        <Button Content="Test Email Connection" Command="{Binding TestEmailCommand}" 
                                IsEnabled="{Binding EmailEnabled}" HorizontalAlignment="Left" />
                        <TextBlock Text="{Binding TestEmailStatus}" Opacity="0.7" FontSize="12"
                                   IsVisible="{Binding TestEmailStatus, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Syslog -->
            <TabItem Header="Syslog">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Syslog Settings" FontWeight="Bold" FontSize="16" />

                        <CheckBox Content="Enable Syslog Forwarding" IsChecked="{Binding SyslogEnabled}" />

                        <StackPanel Spacing="4" IsEnabled="{Binding SyslogEnabled}">
                            <TextBlock Text="Syslog Server" />
                            <TextBox Text="{Binding SyslogServer}" Watermark="syslog.example.com" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding SyslogEnabled}">
                            <TextBlock Text="Port" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding SyslogPort}" Minimum="1" Maximum="65535" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding SyslogEnabled}">
                            <TextBlock Text="Protocol" />
                            <ComboBox x:CompileBindings="False" 
                                      ItemsSource="{Binding SyslogProtocolOptions}" 
                                      SelectedItem="{Binding SyslogProtocol}"
                                      Width="150" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Alerts -->
            <TabItem Header="Alerts">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Alert Settings" FontWeight="Bold" FontSize="16" />

                        <StackPanel Spacing="4">
                            <TextBlock Text="Master Cooldown Period (minutes)" />
                            <TextBlock Text="Maximum one email per this period." FontSize="11" Opacity="0.6" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding MasterCooldownMinutes}" Minimum="1" Maximum="1440" Increment="1" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Export -->
            <TabItem Header="Export">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="HTML Report Export" FontWeight="Bold" FontSize="16" />

                        <CheckBox Content="Enable Scheduled Export" IsChecked="{Binding ExportEnabled}" />

                        <StackPanel Spacing="4" IsEnabled="{Binding ExportEnabled}">
                            <TextBlock Text="Export Path" />
                            <TextBox Text="{Binding ExportPath}" Watermark="C:\Reports\AGMonitor" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding ExportEnabled}">
                            <TextBlock Text="Export Interval (minutes)" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding ExportIntervalMinutes}" Minimum="1" Maximum="10080" Increment="5" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- History -->
            <TabItem Header="History">
                <ScrollViewer Padding="8">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Alert History Retention" FontWeight="Bold" FontSize="16" />
                        <TextBlock Text="Controls automatic cleanup of old alert records in the event database." 
                                   FontSize="12" Opacity="0.6" TextWrapping="Wrap" />

                        <CheckBox Content="Enable automatic pruning" IsChecked="{Binding AutoPruneEnabled}" />

                        <StackPanel Spacing="4" IsEnabled="{Binding AutoPruneEnabled}">
                            <TextBlock Text="Maximum age (days)" />
                            <TextBlock Text="Alerts older than this are automatically deleted. Leave at 0 to disable." 
                                       FontSize="11" Opacity="0.6" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding MaxRetentionDays}" 
                                           Minimum="0" Maximum="3650" Increment="1" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>

                        <StackPanel Spacing="4" IsEnabled="{Binding AutoPruneEnabled}">
                            <TextBlock Text="Maximum number of records" />
                            <TextBlock Text="Only the most recent N records are kept. Leave at 0 for unlimited." 
                                       FontSize="11" Opacity="0.6" />
                            <NumericUpDown x:CompileBindings="False" Value="{Binding MaxRecords}" 
                                           Minimum="0" Maximum="10000000" Increment="1000" 
                                           Width="150" HorizontalAlignment="Left" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
