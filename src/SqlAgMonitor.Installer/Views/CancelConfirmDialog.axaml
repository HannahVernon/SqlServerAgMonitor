<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SqlAgMonitor.Installer.Views.CancelConfirmDialog"
        Title="Cancel Installation?"
        Width="480" Height="340"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Icon="avares://SqlAgMonitor.Installer/Assets/app-icon.png">

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" 
                    HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
            <Button Content="Yes, Cancel" x:Name="ConfirmButton" MinWidth="100" />
            <Button Content="No, Go Back" x:Name="GoBackButton" MinWidth="100" Classes="accent" />
        </StackPanel>

        <StackPanel Spacing="12">
            <TextBlock x:Name="HeadingText" Text="⚠ Cancel Installation?" 
                       FontSize="16" FontWeight="SemiBold" Foreground="#FFFFAA00" />

            <ScrollViewer MaxHeight="220">
                <TextBlock x:Name="MessageText" TextWrapping="Wrap" LineHeight="20" />
            </ScrollViewer>
        </StackPanel>
    </DockPanel>
</Window>
